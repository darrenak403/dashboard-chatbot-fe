# =============================================================================
# FPT Admission Dashboard — Environment variables
# Copy: cp docker/.env.example docker/.env
# =============================================================================

# -----------------------------------------------------------------------------
# Application (dev trên host — task dev)
# -----------------------------------------------------------------------------
PORT=3000

# API URLs — bake vào bundle khi build (Docker / CI). Dev local có thể export trước khi build.
NEXT_PUBLIC_API_BASE_URL=http://localhost:2222
NEXT_PUBLIC_KNOWLEDGE_API_BASE_URL=http://localhost:8000/v1/api

# -----------------------------------------------------------------------------
# Production (docker-compose.prod.yml — local hoặc Dokploy UI)
# Khớp image GitHub Actions: ${DOCKER_USERNAME}/fpt-admission-dashboard
# -----------------------------------------------------------------------------
# DOCKER_USERNAME=your-dockerhub-username
# APP_TAG=latest
# PORT=3000
# NEXT_PUBLIC_API_BASE_URL=https://your-api.example.com
# NEXT_PUBLIC_KNOWLEDGE_API_BASE_URL=https://your-knowledge-api.example.com/v1/api
